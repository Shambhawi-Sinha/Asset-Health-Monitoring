# ─────────────────────────────────────────────
# Oracle Autonomous DB (OCI)
# ─────────────────────────────────────────────
OCI_DB_USERNAME=your_db_username
OCI_DB_PASSWORD=your_db_password
OCI_DB_DSN=your_tns_alias                        # e.g. mydb_high
OCI_WALLET_DIR=/path/to/backend/wallet           # folder containing ewallet.pem, tnsnames.ora, sqlnet.ora
OCI_WALLET_PASSWORD=your_wallet_password

# ─────────────────────────────────────────────
# Azure OpenAI
# ─────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_GPT4=gpt-4               # deployment name for GPT-4
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# ─────────────────────────────────────────────
# Azure AI Search
# ─────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your_azure_search_key
AZURE_SEARCH_INDEX_NAME=substation-docs

# ─────────────────────────────────────────────
# Azure AI Vision
# ─────────────────────────────────────────────
AZURE_VISION_ENDPOINT=https://your-vision-resource.cognitiveservices.azure.com/
AZURE_VISION_API_KEY=your_azure_vision_key

# ─────────────────────────────────────────────
# Fulcrum (Field Inspection Image API)
# ─────────────────────────────────────────────
FULCRUM_API_KEY=your_fulcrum_api_key
FULCRUM_BASE_URL=https://api.fulcrumapp.com/api/v2

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:3000
MOCK_MODE=false                                  # set to true to use sample_data/ instead of live Oracle
